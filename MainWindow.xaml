<Window x:Class="GestLog.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GestLog"
        mc:Ignorable="d"
        Title="GestLog" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button" BasedOn="{StaticResource ThemeHeaderSecondaryButtonStyle}"/>

        <Style x:Key="StatusIndicatorStyle" TargetType="Border">
            <Setter Property="Background" Value="#C0392B"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="3" ShadowDepth="1" Opacity="0.15"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusIndicatorConnectedStyle" TargetType="Border">
            <Setter Property="Background" Value="#2B8E3F"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="3" ShadowDepth="1" Opacity="0.15"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ConfigButtonStyle" TargetType="Button" BasedOn="{StaticResource ThemeHeaderSecondaryButtonStyle}"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border x:Name="navbar"
                Grid.Row="0"
                Padding="18,12"
                Visibility="{Binding IsAuthenticated, Converter={StaticResource BooleanToVisibilityConverter}}"
                Style="{DynamicResource ThemeHeaderContainerStyle}">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="6" ShadowDepth="2" Opacity="0.12"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="btnHome"
                            Content="🏠 Home"
                            Background="{DynamicResource HeaderSecondaryButtonBrush}"
                            Foreground="White"
                            Padding="16,8"
                            BorderThickness="0"
                            FontFamily="Segoe UI"
                            FontWeight="SemiBold"
                            FontSize="14"
                            Margin="0,0,12,0"
                            Click="btnHome_Click"
                            Style="{StaticResource NavButtonStyle}"/>

                    <Button x:Name="btnBack"
                            Content="⬅️ Regresar"
                            Background="{DynamicResource HeaderSecondaryButtonBrush}"
                            Foreground="White"
                            Padding="16,8"
                            BorderThickness="0"
                            FontFamily="Segoe UI"
                            FontWeight="SemiBold"
                            FontSize="14"
                            Margin="0,0,16,0"
                            Click="btnBack_Click"
                            Visibility="Collapsed"
                            Style="{StaticResource NavButtonStyle}"/>

                    <TextBlock x:Name="txtCurrentView"
                              Text="Home"
                              Foreground="#FFFFFF"
                              FontFamily="Segoe UI"
                              FontSize="16"
                              FontWeight="SemiBold"
                              VerticalAlignment="Center"
                              Margin="16,0,0,0">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="2" ShadowDepth="1" Opacity="0.25"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding NombrePersonaActual}"
                               Foreground="White"
                               FontFamily="Segoe UI"
                               FontWeight="SemiBold"
                               FontSize="15"
                               VerticalAlignment="Center"
                               Margin="0,0,18,0"/>

                    <Border x:Name="DatabaseStatusBorder"
                            CornerRadius="6"
                            Padding="10,6"
                            Margin="0,0,12,0"
                            ToolTip="{Binding DatabaseStatusTooltip}"
                            Background="{Binding DatabaseStatusBackground}"
                            Style="{StaticResource StatusIndicatorStyle}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="DatabaseStatusIcon"
                                      Text="{Binding DatabaseStatusIcon}"
                                      Foreground="White"
                                      FontFamily="Segoe UI"
                                      FontWeight="Bold"
                                      Margin="0,0,6,0"
                                      VerticalAlignment="Center"/>
                            <TextBlock x:Name="DatabaseStatusText"
                                      Text="{Binding DatabaseStatusText}"
                                      Foreground="White"
                                      FontFamily="Segoe UI"
                                      FontSize="11"
                                      FontWeight="SemiBold"
                                      VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Button x:Name="btnCerrarSesion"
                            Content="🔒 Cerrar sesión"
                            Background="{DynamicResource HeaderSecondaryButtonBrush}"
                            Foreground="White"
                            BorderThickness="0"
                            FontFamily="Segoe UI"
                            FontWeight="SemiBold"
                            FontSize="15"
                            Width="140"
                            Height="40"
                            ToolTip="Cerrar sesión"
                            Command="{Binding CerrarSesionCommand}"
                            Style="{StaticResource ConfigButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <ContentControl x:Name="contentPanel">
                <ContentControl.Background>
                    <SolidColorBrush Color="#FAFAFA"/>
                </ContentControl.Background>
            </ContentControl>
        </Grid>
    </Grid>
</Window>
