<UserControl x:Class="GestLog.Modules.EnvioCatalogo.Views.EnvioCatalogoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:GestLog.Converters"
             xmlns:controls="clr-namespace:GestLog.Controls"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <converters:PathToFileNameConverter x:Key="PathToFileNameConverter"/>
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
            <converters:BooleanToColorConverter x:Key="BooleanToColorConverter"/>
            <converters:BooleanToOpacityConverter x:Key="BooleanToOpacityConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Style="{DynamicResource ThemeRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="40,30,40,20">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
                    <Border Style="{DynamicResource ThemeCardIconCircleStyle}" Width="80" Height="80" CornerRadius="40" Margin="0,0,20,0">
                        <TextBlock Text="📧" Style="{DynamicResource ThemeCardIconTextStyle}" FontSize="40"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Envío de Catálogo" Style="{DynamicResource ThemeSectionTitleStyle}" FontSize="28"/>
                        <TextBlock Text="Envío masivo del catálogo de productos y servicios a múltiples clientes" Style="{DynamicResource ThemeSectionSubtitleStyle}" FontSize="16"/>
                    </StackPanel>
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{DynamicResource BackgroundAppBrush}">
                    <StackPanel Margin="0" Background="{DynamicResource BackgroundAppBrush}">
                        <Border Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Margin="0,0,0,10"
                                Padding="20,20,20,20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{DynamicResource ThemeElevatedCardStyle}" Padding="20" CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Text="📊" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="{DynamicResource PrimaryBrush}"/>
                                        <TextBlock Text="Archivo Excel con Emails"
                                                   FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="14"
                                                   HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                        <TextBlock Text="{Binding ExcelFileName, TargetNullValue='Ningún archivo seleccionado'}"
                                                   FontFamily="Segoe UI" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"
                                                   HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,12"/>
                                        <Button Content="📂 Seleccionar Excel"
                                                Style="{DynamicResource ThemePrimaryButtonStyle}"
                                                Padding="12,8"
                                                FontSize="12"
                                                Command="{Binding SelectExcelFileCommand}"
                                                IsEnabled="{Binding CanSendCatalogPermission}"
                                                Opacity="{Binding CanSendCatalogPermission, Converter={StaticResource BooleanToOpacityConverter}}"/>

                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Padding="6,4" CornerRadius="6" HorizontalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasExcelFile}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Foreground="{DynamicResource TextOnPrimaryBrush}" FontFamily="Segoe UI" FontSize="9" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="❌ Sin Excel"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding HasExcelFile}" Value="True">
                                                                    <Setter Property="Text" Value="✅ Excel OK"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>

                                            <Border Grid.Column="2" Padding="6,4" CornerRadius="6" Background="{DynamicResource SuccessBrush}" HorizontalAlignment="Center">
                                                <TextBlock Text="✅ Catálogo OK" Foreground="{DynamicResource TextOnPrimaryBrush}" FontFamily="Segoe UI" FontSize="9" FontWeight="SemiBold"/>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="2" Style="{DynamicResource ThemeElevatedCardStyle}" Padding="20" CornerRadius="10">
                                    <StackPanel>
                                        <TextBlock Text="📧" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="{DynamicResource PrimaryBrush}"/>
                                        <TextBlock Text="Configuración SMTP"
                                                   FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="14"
                                                   HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                                            <Ellipse Width="10" Height="10" Margin="0,0,6,0" VerticalAlignment="Center">
                                                <Ellipse.Fill>
                                                    <SolidColorBrush Color="{Binding IsSmtpConfigured, Converter={StaticResource BooleanToColorConverter}}"/>
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <TextBlock FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="No configurado"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSmtpConfigured}" Value="True">
                                                                <Setter Property="Text" Value="Configurado"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>

                                        <StackPanel Visibility="{Binding IsSmtpConfigured, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,10">
                                            <TextBlock FontFamily="Segoe UI" FontSize="10" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,1" Foreground="{DynamicResource TextBodyBrush}">
                                                <Run Text="Usuario: " FontWeight="SemiBold"/>
                                                <Run Text="{Binding SmtpUsername}"/>
                                            </TextBlock>
                                            <TextBlock FontFamily="Segoe UI" FontSize="10" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,1" Foreground="{DynamicResource TextBodyBrush}">
                                                <Run Text="Servidor: " FontWeight="SemiBold"/>
                                                <Run Text="{Binding SmtpServer}"/>
                                                <Run Text=":"/>
                                                <Run Text="{Binding SmtpPort}" FontWeight="SemiBold"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <TextBlock Text="Configure el servidor SMTP para habilitar el envío del catálogo"
                                                   FontFamily="Segoe UI"
                                                   FontSize="10"
                                                   FontStyle="Italic"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="0,0,0,10"
                                                   Visibility="{Binding IsSmtpConfigured, Converter={StaticResource InverseBooleanConverter}, ConverterParameter=Visibility}"/>
                                        <Button Content="⚙️ Configurar"
                                                Style="{DynamicResource ThemePrimaryButtonStyle}"
                                                Padding="12,8"
                                                FontSize="12"
                                                HorizontalAlignment="Center"
                                                Click="ConfigureSmtp_Click"
                                                IsEnabled="{Binding CanSendCatalogPermission}"
                                                Opacity="{Binding CanSendCatalogPermission, Converter={StaticResource BooleanToOpacityConverter}}"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <Button Content="🚀 Enviar Catálogo"
                                Style="{DynamicResource ThemePrimaryButtonStyle}"
                                Padding="20,12"
                                FontSize="16"
                                HorizontalAlignment="Center"
                                Margin="20,8,20,15"
                                Command="{Binding SendCatalogoCommand}"
                                IsEnabled="{Binding CanSendCatalogo}"
                                Opacity="{Binding CanSendCatalogo, Converter={StaticResource BooleanToOpacityConverter}}"/>

                        <Border Style="{DynamicResource ThemeElevatedCardStyle}"
                                Padding="20"
                                CornerRadius="10"
                                Margin="20,0,20,15"
                                Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <controls:SimpleProgressBar ProgressValue="{Binding ProgressValue}"
                                                            Title="📧 Enviando Catálogo"
                                                            StatusMessage="{Binding StatusMessage}"
                                                            BackgroundColor="{DynamicResource BackgroundSurfaceBrush}"
                                                            TitleColor="{DynamicResource TextPrimaryBrush}"
                                                            PercentageColor="{DynamicResource PrimaryBrush}"
                                                            MessageColor="{DynamicResource TextSecondaryBrush}"
                                                            BarForeground="{DynamicResource PrimaryBrush}"
                                                            BarBackground="{DynamicResource TableHeaderBrush}"
                                                            BarHeight="20"/>

                                <Button Content="❌ Cancelar Envío"
                                        Background="{DynamicResource DangerBrush}"
                                        Foreground="{DynamicResource TextOnPrimaryBrush}"
                                        FontFamily="Segoe UI"
                                        Padding="12,8"
                                        BorderThickness="0"
                                        FontWeight="SemiBold"
                                        FontSize="12"
                                        HorizontalAlignment="Center"
                                        Margin="0,15,0,0"
                                        Command="{Binding CancelSendingCommand}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{DynamicResource ThemeElevatedCardStyle}"
                                Padding="20"
                                CornerRadius="10"
                                Margin="20,0,20,20"
                                Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="📊 Total" FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding TotalEmails}" FontFamily="Segoe UI" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="🔄 Procesados" FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding ProcessedEmails}" FontFamily="Segoe UI" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="✅ Exitosos" FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding SuccessfulSends}" FontFamily="Segoe UI" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                    <TextBlock Text="❌ Fallidos" FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding FailedSends}" FontFamily="Segoe UI" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource DangerBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

