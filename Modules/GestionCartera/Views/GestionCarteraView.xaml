<UserControl x:Class="GestLog.Modules.GestionCartera.Views.GestionCarteraView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:GestLog.Converters"
             xmlns:controls="clr-namespace:GestLog.Controls"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">
    <UserControl.Resources>
        <ResourceDictionary>
            <converters:PathToFileNameConverter x:Key="PathToFileNameConverter"/>
            <converters:FileSizeConverter x:Key="FileSizeConverter"/>
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <converters:BooleanToColorConverter x:Key="BooleanToColorConverter"/>
            <converters:BooleanToStatusTextConverter x:Key="BooleanToStatusTextConverter"/>
            <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
            <converters:ProgressToWidthConverter x:Key="ProgressToWidthConverter"/>
            <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
            <converters:BooleanToOpacityConverter x:Key="BooleanToOpacityConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Style="{DynamicResource ThemeRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="30,22,30,14">
            <StackPanel>
                <Border Style="{DynamicResource ThemeWelcomeCardStyle}" Padding="30,24" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="1.2*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Style="{DynamicResource ThemeCardIconCircleStyle}" Width="74" Height="74" CornerRadius="37" Margin="0,0,14,0">
                                    <TextBlock Text="📧" Style="{DynamicResource ThemeCardIconTextStyle}" FontSize="34"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Gestión de Cartera" Style="{DynamicResource ThemeSectionTitleStyle}" FontSize="30"/>
                                    <TextBlock Text="Centro unificado de generación y envío de documentos" Style="{DynamicResource ThemeSectionSubtitleStyle}" FontSize="15"/>
                                </StackPanel>
                            </StackPanel>

                            <TextBlock Text="Carga de Excel, generación de estados de cuenta y envío automático de documentos en un único flujo de trabajo optimizado." Style="{DynamicResource ThemeBodyTextStyle}" FontSize="14" TextWrapping="Wrap" MaxWidth="760"/>
                        </StackPanel>

                        <Border Grid.Column="2" Style="{DynamicResource ThemeInfoNoticeStyle}" Padding="20,16">
                            <StackPanel>
                                <TextBlock Text="Estado SMTP" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                    <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <Ellipse.Fill>
                                            <SolidColorBrush Color="{Binding IsEmailConfigured, Converter={StaticResource BooleanToColorConverter}}"/>
                                        </Ellipse.Fill>
                                    </Ellipse>
                                    <TextBlock Text="{Binding IsEmailConfigured, Converter={StaticResource BooleanToStatusTextConverter}}" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <TextBlock Text="Con correo" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding CompaniesWithEmail, StringFormat={}{0:N0}}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,10"/>
                                <TextBlock Text="Sin correo" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding CompaniesWithoutEmail, StringFormat={}{0:N0}}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource WarningBrush}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{DynamicResource ThemeElevatedCardStyle}" Padding="24,20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="📄 Generación de Documentos" Style="{DynamicResource ThemeCardTitleStyle}" FontSize="20" Margin="0,0,0,16"/>

                            <StackPanel Grid.Row="1">
                                <Border Background="{DynamicResource SurfaceLayer2Brush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Archivo Excel de cartera" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding SelectedExcelFilePath, Converter={StaticResource PathToFileNameConverter}, TargetNullValue='Ningún archivo seleccionado'}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,5,0,10" MaxHeight="36" TextTrimming="CharacterEllipsis"/>
                                        <Button Content="📂 Seleccionar archivo" Style="{DynamicResource ThemePrimaryButtonStyle}" Command="{Binding SelectExcelFileCommand}" HorizontalAlignment="Stretch" MinHeight="36" Padding="14,8"/>
                                    </StackPanel>
                                </Border>

                                <Border Background="{DynamicResource SurfaceLayer2Brush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,14" MinHeight="108">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0">
                                            <TextBlock Text="Carpeta predeterminada de salida" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center" Fill="{DynamicResource PrimaryBrush}"/>
                                                <TextBlock Text="Disponible" FontWeight="SemiBold" FontSize="12" Foreground="{DynamicResource PrimaryBrush}"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding OutputFolderPath, TargetNullValue='Ruta no disponible'}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,0" MaxHeight="32" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Button Grid.Row="2" Content="🗂️ Abrir carpeta" Style="{DynamicResource ThemeSecondaryButtonStyle}" Command="{Binding OpenOutputFolderCommand}" HorizontalAlignment="Stretch" Height="36" Padding="14,8"/>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <Button Grid.Row="2"
                                    Content="🚀 Generar estados de cuenta"
                                    Style="{DynamicResource ThemePrimaryButtonStyle}"
                                    Command="{Binding GenerateDocumentsCommand}"
                                    IsEnabled="{Binding PdfCanGenerateDocuments}"
                                    Opacity="{Binding PdfCanGenerateDocuments, Converter={StaticResource BooleanToOpacityConverter}}"
                                    HorizontalAlignment="Stretch"
                                    MinHeight="38"
                                    Padding="18,10"/>
                        </Grid>
                    </Border>

                    <Border x:Name="EmailSectionCard" Grid.Column="2" Style="{DynamicResource ThemeElevatedCardStyle}" Padding="24,20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="🚀 Envío Automático" Style="{DynamicResource ThemeCardTitleStyle}" FontSize="20" Margin="0,0,0,16"/>

                            <StackPanel Grid.Row="1">
                                <Border Background="{DynamicResource SurfaceLayer2Brush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,12">
                                    <StackPanel>
                                        <TextBlock Text="Excel de correos" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding SelectedEmailExcelFilePath, Converter={StaticResource PathToFileNameConverter}, TargetNullValue='Ningún archivo seleccionado'}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,5,0,8" MaxHeight="36" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding CompaniesStatusText}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}" Visibility="{Binding HasEmailExcel, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,6"/>
                                        <TextBlock Text="{Binding DocumentStatusWarning}" FontSize="10" FontStyle="Italic" Foreground="{DynamicResource WarningBrush}" Visibility="{Binding DocumentStatusWarning, Converter={StaticResource StringToVisibilityConverter}}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                        <Button Content="📂 Seleccionar archivo" Style="{DynamicResource ThemePrimaryButtonStyle}" Command="{Binding SelectEmailExcelFileCommand}" IsEnabled="{Binding CanSelectExcelFile}" Opacity="{Binding CanSelectExcelFile, Converter={StaticResource BooleanToOpacityConverter}}" HorizontalAlignment="Stretch" MinHeight="36" Padding="14,8"/>
                                    </StackPanel>
                                </Border>

                                <Border Background="{DynamicResource SurfaceLayer2Brush}" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,14" MinHeight="108">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <StackPanel Grid.Row="0">
                                            <TextBlock Text="Configuración SMTP" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                                                    <Ellipse.Fill>
                                                        <SolidColorBrush Color="{Binding IsEmailConfigured, Converter={StaticResource BooleanToColorConverter}}"/>
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                                <TextBlock Text="{Binding IsEmailConfigured, Converter={StaticResource BooleanToStatusTextConverter}}" FontWeight="SemiBold" FontSize="12"/>
                                            </StackPanel>
                                            <TextBlock FontSize="11" TextWrapping="Wrap" Margin="0,0,0,0">
                                                <Run Text="Usuario: " FontWeight="SemiBold"/>
                                                <Run Text="{Binding SmtpUsername}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <Button Grid.Row="2" Content="⚙️ Configurar SMTP" Style="{DynamicResource ThemeSecondaryButtonStyle}" Click="ConfigureSmtp_Click" IsEnabled="{Binding CanConfigureSmtp}" Opacity="{Binding CanConfigureSmtp, Converter={StaticResource BooleanToOpacityConverter}}" HorizontalAlignment="Stretch" Height="36" Padding="14,8"/>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <Button Grid.Row="2"
                                    Content="🚀 Enviar documentos automáticamente"
                                    Style="{DynamicResource ThemePrimaryButtonStyle}"
                                    Command="{Binding SendDocumentsAutomaticallyCommand}"
                                    IsEnabled="{Binding AutoCanSendDocuments}"
                                    Opacity="{Binding AutoCanSendDocuments, Converter={StaticResource BooleanToOpacityConverter}}"
                                    HorizontalAlignment="Stretch"
                                    MinHeight="38"
                                    Padding="18,10"/>
                        </Grid>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.RowSpan="2" Background="#80000000" Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="50">
            <Border Style="{DynamicResource ThemeElevatedCardStyle}"
                    MaxWidth="760"
                    MinWidth="520"
                    Padding="24,20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="🔄 Generando Estados de Cuenta" Style="{DynamicResource ThemeCardTitleStyle}" FontSize="20" Margin="0,0,0,14" HorizontalAlignment="Center"/>
                    <controls:SimpleProgressBar ProgressValue="{Binding ProgressValue}"
                                                Title="Progreso de generación"
                                                StatusMessage="{Binding StatusMessage}"
                                                BackgroundColor="{DynamicResource BackgroundSurfaceBrush}"
                                                TitleColor="{DynamicResource TextPrimaryBrush}"
                                                PercentageColor="{DynamicResource PrimaryBrush}"
                                                MessageColor="{DynamicResource TextSecondaryBrush}"
                                                BarForeground="{DynamicResource PrimaryBrush}"
                                                BarBackground="{DynamicResource BorderDefaultBrush}"
                                                BarHeight="16"/>
                    <Button Content="❌ Cancelar Generación"
                            Background="{DynamicResource DangerBrush}"
                            Foreground="{DynamicResource TextOnPrimaryBrush}"
                            Padding="14,9"
                            FontSize="12"
                            HorizontalAlignment="Center"
                            Margin="0,14,0,0"
                            MinWidth="180"
                            BorderThickness="0"
                            Command="{Binding CancelGenerationCommand}"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.RowSpan="2" Background="#80000000" Visibility="{Binding IsSendingEmail, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="50">
            <Border Style="{DynamicResource ThemeElevatedCardStyle}"
                    MaxWidth="760"
                    MinWidth="520"
                    Padding="24,20"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="📧 Enviando Documentos por Email" Style="{DynamicResource ThemeCardTitleStyle}" FontSize="20" Margin="0,0,0,14" HorizontalAlignment="Center"/>
                    <controls:SimpleProgressBar ProgressValue="{Binding EmailProgressValue}"
                                                Title="Progreso de envío"
                                                StatusMessage="{Binding EmailStatusMessage}"
                                                BackgroundColor="{DynamicResource BackgroundSurfaceBrush}"
                                                TitleColor="{DynamicResource TextPrimaryBrush}"
                                                PercentageColor="{DynamicResource PrimaryBrush}"
                                                MessageColor="{DynamicResource TextSecondaryBrush}"
                                                BarForeground="{DynamicResource PrimaryBrush}"
                                                BarBackground="{DynamicResource BorderDefaultBrush}"
                                                BarHeight="16"/>
                    <Button Content="❌ Cancelar Envío"
                            Background="{DynamicResource DangerBrush}"
                            Foreground="{DynamicResource TextOnPrimaryBrush}"
                            Padding="14,9"
                            FontSize="12"
                            HorizontalAlignment="Center"
                            Margin="0,14,0,0"
                            MinWidth="180"
                            BorderThickness="0"
                            Command="{Binding CancelEmailSendingCommand}"
                            IsEnabled="{Binding CanCancelEmailSending}"
                            Opacity="{Binding CanCancelEmailSending, Converter={StaticResource BooleanToOpacityConverter}}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>



