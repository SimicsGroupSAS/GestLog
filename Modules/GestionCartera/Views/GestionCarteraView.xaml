<UserControl x:Class="GestLog.Modules.GestionCartera.Views.GestionCarteraView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:GestLog.Converters"
             xmlns:controls="clr-namespace:GestLog.Controls"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">
    <UserControl.Resources>
        <ResourceDictionary>
            <converters:PathToFileNameConverter x:Key="PathToFileNameConverter"/>
            <converters:FileSizeConverter x:Key="FileSizeConverter"/>
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <converters:BooleanToColorConverter x:Key="BooleanToColorConverter"/>
            <converters:BooleanToStatusTextConverter x:Key="BooleanToStatusTextConverter"/>
            <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
            <converters:ProgressToWidthConverter x:Key="ProgressToWidthConverter"/>
            <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
            <converters:BooleanToOpacityConverter x:Key="BooleanToOpacityConverter"/>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Style="{DynamicResource ThemeRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="40,30,40,20">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
                    <Border Style="{DynamicResource ThemeCardIconCircleStyle}" Width="80" Height="80" CornerRadius="40" Margin="0,0,20,0">
                        <TextBlock Text="📧" Style="{DynamicResource ThemeCardIconTextStyle}" FontSize="40"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Gestion de Cartera" Style="{DynamicResource ThemeSectionTitleStyle}" FontSize="28"/>
                        <TextBlock Text="Envio de correos electronicos de cartera vencida" Style="{DynamicResource ThemeSectionSubtitleStyle}" FontSize="16"/>
                    </StackPanel>
                </StackPanel>

                <TabControl x:Name="mainTabControl" Background="{DynamicResource BackgroundSurfaceBrush}" BorderThickness="0" Padding="0">
                    <TabControl.Resources>
                        <Style TargetType="TabItem">
                            <Setter Property="FontFamily" Value="Segoe UI"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="18,10"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            <Setter Property="Background" Value="{DynamicResource BackgroundSurfaceBrush}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TabItem">
                                        <Border Name="Border" Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1,1,1,0"
                                                Margin="2,0" CornerRadius="6,6,0,0">
                                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center"
                                                              HorizontalAlignment="Center" ContentSource="Header"
                                                              Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource BackgroundAppBrush}"/>
                                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource BorderDefaultBrush}"/>
                                                <Setter TargetName="Border" Property="BorderThickness" Value="1,1,1,0"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                <Setter Property="Panel.ZIndex" Value="1"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>

                    <TabItem Header="📄 Generacion de Documentos">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{DynamicResource BackgroundAppBrush}">
                            <StackPanel Margin="0" Background="{DynamicResource BackgroundAppBrush}">
                                <Border Background="{DynamicResource BackgroundAppBrush}" BorderBrush="Transparent" BorderThickness="0" Margin="0,0,0,10" Padding="20,20,20,20">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Style="{DynamicResource ThemeElevatedCardStyle}" Padding="20" CornerRadius="10">
                                            <StackPanel>
                                                <TextBlock Text="📊" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="{DynamicResource PrimaryBrush}"/>
                                                <TextBlock Text="Archivo Excel de Cartera" FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                                <TextBlock Text="{Binding SelectedExcelFilePath, Converter={StaticResource PathToFileNameConverter}, TargetNullValue='Ningun archivo seleccionado'}" FontFamily="Segoe UI" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,12"/>
                                                <Button Content="📂 Seleccionar Archivo" Style="{DynamicResource ThemePrimaryButtonStyle}" Padding="12,8" FontSize="12" Command="{Binding SelectExcelFileCommand}"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="2" Style="{DynamicResource ThemeElevatedCardStyle}" Padding="20" CornerRadius="10">
                                            <StackPanel>
                                                <TextBlock Text="📁" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="{DynamicResource PrimaryBrush}"/>
                                                <TextBlock Text="Carpeta de Destino" FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                                <TextBlock Text="{Binding OutputFolderPath, TargetNullValue='Carpeta por defecto'}" FontFamily="Segoe UI" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,12"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <Button Content="📂 Seleccionar" Style="{DynamicResource ThemePrimaryButtonStyle}" Padding="10,6" FontSize="11" Margin="0,0,8,0" Command="{Binding SelectOutputFolderCommand}" IsEnabled="{Binding CanGenerateDocuments}" Opacity="{Binding CanGenerateDocuments, Converter={StaticResource BooleanToOpacityConverter}}"/>
                                                    <Button Content="🗂️" Style="{DynamicResource ThemeSecondaryButtonStyle}" Width="30" Height="30" ToolTip="Abrir carpeta" Command="{Binding OpenOutputFolderCommand}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Button Content="🚀 Generar Estados de Cuenta" Style="{DynamicResource ThemePrimaryButtonStyle}" Padding="20,12" FontSize="14" HorizontalAlignment="Center" Margin="20,8,20,15" Command="{Binding GenerateDocumentsCommand}" IsEnabled="{Binding PdfCanGenerateDocuments}" Opacity="{Binding PdfCanGenerateDocuments, Converter={StaticResource BooleanToOpacityConverter}}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="🚀 Envio Automatico">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{DynamicResource BackgroundAppBrush}">
                            <StackPanel Margin="0" Background="{DynamicResource BackgroundAppBrush}">
                                <Border Background="{DynamicResource BackgroundAppBrush}" BorderBrush="Transparent" BorderThickness="0" Margin="0,0,0,10" Padding="20,20,20,20">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Style="{DynamicResource ThemeElevatedCardStyle}" Padding="20" CornerRadius="10">
                                            <StackPanel>
                                                <TextBlock Text="📊" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="{DynamicResource PrimaryBrush}"/>
                                                <TextBlock Text="Excel de Correos" FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                                <TextBlock Text="{Binding SelectedEmailExcelFilePath, Converter={StaticResource PathToFileNameConverter}, TargetNullValue='Ningun archivo seleccionado'}" FontFamily="Segoe UI" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,10"/>

                                                <StackPanel Visibility="{Binding HasEmailExcel, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,10">
                                                    <TextBlock FontFamily="Segoe UI" FontSize="11" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" Text="{Binding CompaniesStatusText}"/>
                                                    <TextBlock FontFamily="Segoe UI" FontSize="10" HorizontalAlignment="Center" Foreground="{DynamicResource WarningBrush}" FontStyle="Italic" FontWeight="SemiBold" Text="{Binding DocumentStatusWarning}" Visibility="{Binding DocumentStatusWarning, Converter={StaticResource StringToVisibilityConverter}}" Margin="0,2,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                                                </StackPanel>

                                                <Button Content="📂 Seleccionar Archivo" Style="{DynamicResource ThemePrimaryButtonStyle}" Padding="12,8" FontSize="12" Command="{Binding SelectEmailExcelFileCommand}" IsEnabled="{Binding CanSelectExcelFile}" Opacity="{Binding CanSelectExcelFile, Converter={StaticResource BooleanToOpacityConverter}}"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="2" Style="{DynamicResource ThemeElevatedCardStyle}" Padding="20" CornerRadius="10">
                                            <StackPanel>
                                                <TextBlock Text="📧" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="{DynamicResource PrimaryBrush}"/>
                                                <TextBlock Text="Configuracion SMTP" FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Center" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>

                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                                                    <Ellipse Width="10" Height="10" Margin="0,0,6,0" VerticalAlignment="Center">
                                                        <Ellipse.Fill>
                                                            <SolidColorBrush Color="{Binding IsEmailConfigured, Converter={StaticResource BooleanToColorConverter}}"/>
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                    <TextBlock Text="{Binding IsEmailConfigured, Converter={StaticResource BooleanToStatusTextConverter}}" FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                                                </StackPanel>

                                                <StackPanel Visibility="{Binding IsEmailConfigured, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,0,10">
                                                    <TextBlock FontFamily="Segoe UI" FontSize="10" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,1">
                                                        <Run Text="Usuario: " FontWeight="SemiBold"/>
                                                        <Run Text="{Binding SmtpUsername}"/>
                                                    </TextBlock>
                                                    <TextBlock FontFamily="Segoe UI" FontSize="10" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,1">
                                                        <Run Text="Servidor: " FontWeight="SemiBold"/>
                                                        <Run Text="{Binding SmtpServer}"/>
                                                        <Run Text=":"/>
                                                        <Run Text="{Binding SmtpPort}" FontWeight="SemiBold"/>
                                                    </TextBlock>
                                                    <TextBlock FontFamily="Segoe UI" FontSize="10" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,2,0,1" Visibility="{Binding BccEmail, Converter={StaticResource StringToVisibilityConverter}}">
                                                        <Run Text="BCC: " FontWeight="SemiBold" Foreground="{DynamicResource WarningBrush}"/>
                                                        <Run Text="{Binding BccEmail, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <TextBlock FontFamily="Segoe UI" FontSize="10" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,1" Visibility="{Binding CcEmail, Converter={StaticResource StringToVisibilityConverter}}">
                                                        <Run Text="CC: " FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}"/>
                                                        <Run Text="{Binding CcEmail, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <TextBlock Text="Configure el servidor SMTP para habilitar el envio automatico" FontFamily="Segoe UI" FontSize="10" FontStyle="Italic" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,10" Visibility="{Binding IsEmailConfigured, Converter={StaticResource InverseBooleanConverter}, ConverterParameter=Visibility}"/>

                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                    <Button Content="⚙️ Configurar" Style="{DynamicResource ThemePrimaryButtonStyle}" Padding="10,6" FontSize="11" Margin="0,0,6,0" Click="ConfigureSmtp_Click" IsEnabled="{Binding CanConfigureSmtp}" Opacity="{Binding CanConfigureSmtp, Converter={StaticResource BooleanToOpacityConverter}}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Button Content="🚀 Enviar Documentos Automaticamente" Style="{DynamicResource ThemePrimaryButtonStyle}" Padding="20,12" FontSize="14" HorizontalAlignment="Center" Margin="20,8,20,15" IsEnabled="{Binding AutoCanSendDocuments}" Opacity="{Binding AutoCanSendDocuments, Converter={StaticResource BooleanToOpacityConverter}}" Command="{Binding SendDocumentsAutomaticallyCommand}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" Background="{DynamicResource BackgroundSurfaceBrush}" Padding="20,15" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0" Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
                <controls:SimpleProgressBar ProgressValue="{Binding ProgressValue}"
                                            Title="🔄 Generando Estados de Cuenta"
                                            StatusMessage="{Binding StatusMessage}"
                                            BackgroundColor="{DynamicResource BackgroundSurfaceBrush}"
                                            TitleColor="{DynamicResource TextPrimaryBrush}"
                                            PercentageColor="{DynamicResource PrimaryBrush}"
                                            MessageColor="{DynamicResource TextSecondaryBrush}"
                                            BarForeground="{DynamicResource PrimaryBrush}"
                                            BarBackground="{DynamicResource BorderDefaultBrush}"
                                            BarHeight="16"/>
                <Button Content="❌ Cancelar Generacion"
                        Background="{DynamicResource DangerBrush}"
                        Foreground="{DynamicResource TextOnPrimaryBrush}"
                        Padding="12,8"
                        FontSize="12"
                        HorizontalAlignment="Center"
                        Margin="0,12,0,0"
                        BorderThickness="0"
                        Command="{Binding CancelGenerationCommand}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="{DynamicResource BackgroundSurfaceBrush}" Padding="20,15" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0" Visibility="{Binding ShowCompletionPanel, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
                <TextBlock Text="{Binding CompletionMessage}" FontFamily="Segoe UI" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,15"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="🚀 Ir a Envio de Correos" Style="{DynamicResource ThemePrimaryButtonStyle}" Padding="20,12" FontSize="14" Margin="8" Click="GoToEmailTab_Click" IsEnabled="{Binding CanSendEmails}" Opacity="{Binding CanSendEmails, Converter={StaticResource BooleanToOpacityConverter}}"/>
                    <Button Content="📂 Ver Documentos" Style="{DynamicResource ThemeSecondaryButtonStyle}" Padding="16,12" FontSize="13" Margin="8" Command="{Binding OpenOutputFolderCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="{DynamicResource BackgroundSurfaceBrush}" Padding="20,15" BorderBrush="{DynamicResource BorderDefaultBrush}" BorderThickness="0,1,0,0" Visibility="{Binding IsSendingEmail, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
                <controls:SimpleProgressBar ProgressValue="{Binding EmailProgressValue}"
                                            Title="📧 Enviando Documentos por Email"
                                            StatusMessage="{Binding EmailStatusMessage}"
                                            BackgroundColor="{DynamicResource BackgroundSurfaceBrush}"
                                            TitleColor="{DynamicResource TextPrimaryBrush}"
                                            PercentageColor="{DynamicResource PrimaryBrush}"
                                            MessageColor="{DynamicResource TextSecondaryBrush}"
                                            BarForeground="{DynamicResource PrimaryBrush}"
                                            BarBackground="{DynamicResource BorderDefaultBrush}"
                                            BarHeight="16"/>
                <Button Content="❌ Cancelar Envio"
                        Background="{DynamicResource DangerBrush}"
                        Foreground="{DynamicResource TextOnPrimaryBrush}"
                        Padding="12,8"
                        FontSize="12"
                        HorizontalAlignment="Center"
                        Margin="0,12,0,0"
                        BorderThickness="0"
                        Command="{Binding CancelEmailSendingCommand}"
                        IsEnabled="{Binding CanCancelEmailSending}"
                        Opacity="{Binding CanCancelEmailSending, Converter={StaticResource BooleanToOpacityConverter}}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

