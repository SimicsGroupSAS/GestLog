<UserControl x:Class="GestLog.Modules.DaaterProccesor.Views.DaaterProccesorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:GestLog.Controls"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">

    <Grid Style="{DynamicResource ThemeRootGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="40,30,40,20">
            <StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
                    <Border Style="{DynamicResource ThemeCardIconCircleStyle}" Width="80" Height="80" CornerRadius="40" Margin="0,0,20,0">
                        <TextBlock Text="📊" Style="{DynamicResource ThemeCardIconTextStyle}" FontSize="40"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="DaaterProccesor" Style="{DynamicResource ThemeSectionTitleStyle}" FontSize="28"/>
                        <TextBlock Text="Procesamiento avanzado de archivos Excel" Style="{DynamicResource ThemeSectionSubtitleStyle}" FontSize="16"/>
                    </StackPanel>
                </StackPanel>

                <Border Style="{DynamicResource ThemeElevatedCardStyle}" Padding="30" CornerRadius="12">
                    <StackPanel>
                        <TextBlock Text="Funciones Principales:" Style="{DynamicResource ThemeCardTitleStyle}" FontSize="20" Margin="0,0,0,25"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="25"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{DynamicResource ThemeInteractiveCardStyle}" Padding="25" CornerRadius="10">
                                <StackPanel>
                                    <TextBlock Text="📁" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                                    <TextBlock Text="Procesar Archivos Excel"
                                               Style="{DynamicResource ThemeBodyTextStyle}"
                                               FontWeight="SemiBold"
                                               FontSize="18"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,12"/>
                                    <TextBlock Text="Selecciona una carpeta y procesa todos los archivos Excel contenidos"
                                               Style="{DynamicResource ThemeBodyTextStyle}"
                                               FontSize="14"
                                               TextWrapping="Wrap"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               Margin="0,0,0,20"/>
                                    <Button Content="Seleccionar Carpeta y Procesar"
                                            Style="{DynamicResource ThemePrimaryButtonStyle}"
                                            Command="{Binding ProcessExcelFilesCommand}"
                                            IsEnabled="{Binding CanProcessFiles}"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{DynamicResource ThemeInteractiveCardStyle}" Padding="25" CornerRadius="10">
                                <StackPanel>
                                    <TextBlock Text="🔍" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                                    <TextBlock Text="Filtrar Consolidado"
                                               Style="{DynamicResource ThemeBodyTextStyle}"
                                               FontWeight="SemiBold"
                                               FontSize="18"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,12"/>
                                    <TextBlock Text="Aplicar filtros avanzados a los datos consolidados y exportar resultados"
                                               Style="{DynamicResource ThemeBodyTextStyle}"
                                               FontSize="14"
                                               TextWrapping="Wrap"
                                               HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               Margin="0,0,0,20"/>
                                    <Button Content="Abrir Filtros"
                                            Style="{DynamicResource ThemePrimaryButtonStyle}"
                                            Click="OnOpenFilteredDataViewClick"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1"
                Background="{DynamicResource BackgroundSurfaceBrush}"
                Padding="25,20"
                BorderBrush="{DynamicResource BorderDefaultBrush}"
                BorderThickness="0,1,0,0"
                Visibility="{Binding IsProcessing, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel>
                <controls:SimpleProgressBar ProgressValue="{Binding Progress}"
                                            Title="🔄 Procesando Archivos Excel"
                                            StatusMessage="{Binding StatusMessage}"
                                            BackgroundColor="Transparent"
                                                   TitleColor="{DynamicResource TextPrimaryBrush}"
                                                   PercentageColor="{DynamicResource PrimaryBrush}"
                                                   MessageColor="{DynamicResource TextSecondaryBrush}"
                                  BarForeground="{DynamicResource PrimaryBrush}"
                                  BarBackground="{DynamicResource BorderDefaultBrush}"
                                            BarHeight="18"
                                            CornerRadius="0"
                                            Margin="0,0,0,15"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontFamily="Segoe UI"
                               FontSize="12"
                               Text="{Binding ExecutablePath}"
                               TextTrimming="CharacterEllipsis"/>

                    <Button Grid.Column="1"
                            Content="❌ Cancelar"
                            Background="{DynamicResource DangerBrush}"
                            Foreground="{DynamicResource TextOnPrimaryBrush}"
                            FontFamily="Segoe UI"
                            Padding="12,8"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            FontSize="12"
                            Command="{Binding CancelProcessingCommand}"/>
                </Grid>
            </StackPanel>
        </Border>

    </Grid>
</UserControl>

