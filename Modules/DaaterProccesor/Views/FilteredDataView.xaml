<Window x:Class="GestLog.Modules.DaaterProccesor.Views.FilteredDataView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="🔍 Filtrar Consolidado - Productos de Acero"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="Manual"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed">
    
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/ModalWindowsStandard.xaml"/>
                <ResourceDictionary Source="../../../Resources/ModernStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Grid x:Name="RootGrid"
          Background="#80000000"
          MouseLeftButtonDown="Overlay_MouseLeftButtonDown"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">

        <Border x:Name="Card"
                MinWidth="980"
                MaxWidth="1280"
                MaxHeight="820"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="10"
                Padding="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                BorderThickness="1"
                BorderBrush="{StaticResource BorderBrush}"
                Effect="{StaticResource WindowShadow}"
                MouseLeftButtonDown="Panel_MouseLeftButtonDown">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource PrimaryBrush}"
                        CornerRadius="10,10,0,0"
                        Padding="24,16"
                        Effect="{StaticResource HeaderShadow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="White" CornerRadius="8" Padding="8" Margin="0,0,16,0"
                                    Width="44" Height="44" BorderThickness="0" BorderBrush="Transparent"
                                    Effect="{StaticResource SectionShadow}">
                                <TextBlock Text="🔍" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Filtrar datos consolidados" Style="{StaticResource HeaderTextStyle}" Foreground="White"/>
                                <TextBlock Text="Filtros especializados para productos de acero y perfiles metálicos" Style="{StaticResource SubHeaderTextStyle}" Foreground="White" Margin="0,3,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Style="{StaticResource CloseButton}"
                                Width="28"
                                Height="28"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Click="CancelarButton_Click"
                                ToolTip="Cerrar (Esc)">
                            <Grid Width="12" Height="12">
                                <Line X1="0" Y1="0" X2="12" Y2="12" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="12" Y1="0" X2="0" Y2="12" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Grid>
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="White" Margin="18" CornerRadius="8" BorderBrush="#E5E5E5" BorderThickness="1">
                    <Grid>
                        <DataGrid x:Name="FilteredDataGrid" AutoGenerateColumns="True"
                                 Margin="15" Background="Transparent" BorderThickness="0"
                                 GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                 AlternatingRowBackground="#F8F9FA" RowBackground="Transparent"
                                 FontFamily="Segoe UI" FontSize="12"
                                 CanUserAddRows="False" CanUserDeleteRows="False"
                                 IsReadOnly="True" SelectionMode="Extended"
                                 AutoGeneratingColumn="FilteredDataGrid_AutoGeneratingColumn">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#118938"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="10,8"/>
                                    <Setter Property="BorderBrush" Value="#0F7A30"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                        </DataGrid>

                        <Border x:Name="EmptyStatePanel"
                                Visibility="Visible"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="#F8FAF8"
                                BorderBrush="#DDE6DD"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="28,24"
                                MaxWidth="620">
                            <StackPanel HorizontalAlignment="Center">
                                <Border Width="64"
                                        Height="64"
                                        CornerRadius="32"
                                        Background="#EAF5EC"
                                        Margin="0,0,0,14"
                                        HorizontalAlignment="Center">
                                    <TextBlock Text="📂"
                                              FontSize="28"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                </Border>

                                <TextBlock Text="Aún no hay datos consolidados cargados"
                                          FontFamily="Segoe UI"
                                          FontSize="18"
                                          FontWeight="SemiBold"
                                          Foreground="#2F3B2F"
                                          HorizontalAlignment="Center"
                                          TextAlignment="Center"
                                          Margin="0,0,0,8"/>

                                <TextBlock Text="Selecciona un archivo consolidado para visualizar registros y habilitar los filtros especializados de exportación."
                                          FontFamily="Segoe UI"
                                          FontSize="13"
                                          Foreground="#6C776C"
                                          HorizontalAlignment="Center"
                                          TextAlignment="Center"
                                          TextWrapping="Wrap"
                                          Margin="0,0,0,16"/>

                                <Button Content="📂 Cargar consolidado"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Click="LoadConsolidatedFile_Click"
                                        ToolTip="Seleccionar un archivo consolidado desde cualquier ubicación"
                                        HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0" CornerRadius="0,0,10,10" Padding="20,15">
                    <DockPanel LastChildFill="False">
                        <TextBlock x:Name="txtRecordCount"
                                  Text="Cargue datos consolidados para aplicar filtros especializados"
                                  FontFamily="Segoe UI" FontSize="14"
                                  Foreground="#706F6F"
                                  VerticalAlignment="Center"
                                  Margin="0,0,20,0"
                                  DockPanel.Dock="Left"/>

                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                            <Button x:Name="btnExportFiltros"
                                Content="🏗️ Filtros Productos Acero"
                                   Style="{StaticResource FilterButtonStyle}"
                                   Click="ExportAcerosEspeciales_Click"
                                   Margin="0"
                                IsEnabled="False"
                                   ToolTip="Generar 7 hojas Excel: CONSOLIDADO (todos los datos), ACEROS ESPECIALES (7225400000), LÁMINAS, ROLLOS, ÁNGULOS, CANALES y VIGAS con filtros específicos por categoría"/>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>

