<UserControl x:Class="GestLog.Modules.Shell.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:app="clr-namespace:GestLog"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType">
    <Grid Style="{DynamicResource ThemeRootGridStyle}">        
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="50,40">
                <Border Style="{DynamicResource ThemeWelcomeCardStyle}" Margin="0,0,0,30">
                    <StackPanel>
                        <TextBlock Text="Bienvenido a GestLog" 
                                  Style="{DynamicResource ThemeSectionTitleStyle}"
                                  HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        
                        <TextBlock Text="Sistema modular de gestión empresarial con interfaz unificada" 
                                  Style="{DynamicResource ThemeSectionSubtitleStyle}" 
                                  TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>
                    </StackPanel>
                </Border>
                
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{DynamicResource ThemeInteractiveCardStyle}">
                        <Grid>
                            <StackPanel>
                                <Border Style="{DynamicResource ThemeCardIconCircleStyle}">
                                    <TextBlock Text="🛠️" Style="{DynamicResource ThemeCardIconTextStyle}"/>
                                </Border>
                                <TextBlock Text="Herramientas" Style="{DynamicResource ThemeCardTitleStyle}"
                                          HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock Text="Accede a las herramientas de gestión empresarial" 
                                      Style="{DynamicResource ThemeBodyTextStyle}" TextWrapping="Wrap" 
                                      HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,20"/>
                                <Button Name="btnIrHerramientas" Content="Ir a Herramientas" 
                                       Click="btnIrHerramientas_Click"
                                       Style="{DynamicResource ThemePrimaryButtonStyle}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Grid.Column="2" Style="{DynamicResource ThemeInteractiveCardStyle}">
                        <Grid>
                            <StackPanel>
                                <Border Style="{DynamicResource ThemeCardIconCircleStyle}">
                                    <TextBlock Text="ℹ️" Style="{DynamicResource ThemeCardIconTextStyle}"/>
                                </Border>
                                <TextBlock Text="Información" Style="{DynamicResource ThemeCardTitleStyle}"
                                          HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                <TextBlock FontFamily="Segoe UI" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,0,0,20">
                                <Run Text="Estado del sistema y estadísticas de módulos (" />
                                <Run Text="{x:Static app:BuildVersion.VersionLabel}" FontWeight="SemiBold" />
                                <Run Text=")" />
                            </TextBlock>
                                <Button Name="btnInfo" Click="btnInfo_Click" Style="{DynamicResource ThemePrimaryButtonStyle}">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="Ver Información " />
                                        <TextBlock Text="{x:Static app:BuildVersion.VersionLabel}" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
                
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
