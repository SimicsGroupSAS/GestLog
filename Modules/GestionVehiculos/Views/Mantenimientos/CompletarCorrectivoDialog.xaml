<Window x:Class="GestLog.Modules.GestionVehiculos.Views.Mantenimientos.CompletarCorrectivoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Completar mantenimiento"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Style="{StaticResource ModalWindowBase}">

    <Grid x:Name="RootGrid" Background="#80000000">
        <Border Background="{StaticResource SurfaceBrush}" CornerRadius="12" Padding="0"
                Width="860" MaxHeight="820"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                BorderThickness="0" Effect="{StaticResource WindowShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource PrimaryBrush}" CornerRadius="12,12,0,0" Padding="16,12" Effect="{StaticResource HeaderShadow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="White" CornerRadius="8" Padding="8" Margin="0,0,12,0" Width="36" Height="36" Effect="{StaticResource SectionShadow}">
                                <TextBlock Text="✅" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Completar mantenimiento" FontFamily="Segoe UI" FontSize="18" FontWeight="SemiBold" Foreground="White" />
                                <TextBlock Text="Registrar cierre y soporte de factura" FontFamily="Segoe UI" FontSize="12" Foreground="White" Opacity="0.9" />
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1" Style="{StaticResource CloseButton}" Click="BtnCancel_Click" ToolTip="Cerrar (Esc)">
                            <Grid Width="14" Height="14">
                                <Line X1="0" Y1="0" X2="14" Y2="14" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Line X1="14" Y1="0" X2="0" Y2="14" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Grid>
                        </Button>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" Margin="20" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Kilometraje al completar" FontWeight="SemiBold"/>
                        <TextBox x:Name="TxtKilometraje" Style="{StaticResource InputStyle}" />

                        <TextBlock Text="Responsable" FontWeight="SemiBold"/>
                        <ComboBox x:Name="CmbResponsable"
                                  Style="{StaticResource InputStyle}"
                                  IsEditable="True"
                                  IsTextSearchEnabled="False" />

                        <TextBlock Text="Proveedor" FontWeight="SemiBold"/>
                        <ComboBox x:Name="CmbProveedor"
                                  Style="{StaticResource InputStyle}"
                                  IsEditable="True"
                                  IsTextSearchEnabled="False" />

                        <TextBlock Text="Título del mantenimiento realizado" FontWeight="SemiBold"/>
                        <TextBox x:Name="TxtTituloActividad" Style="{StaticResource InputStyle}" />

                        <TextBlock Text="Costo" FontWeight="SemiBold"/>
                        <TextBox x:Name="TxtCosto" Style="{StaticResource InputStyle}" />

                        <Border BorderBrush="#DADCE0" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,6,0,8" Background="#FAFAFA">
                            <StackPanel>
                                <Border Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="🛒" FontSize="14" Margin="0,0,6,0"/>
                                            <TextBlock Text="Carrito de gastos" FontWeight="SemiBold" Foreground="#1E3A8A"/>
                                            <TextBlock Text=" · Ítems:" Foreground="#1E3A8A" Margin="10,0,0,0"/>
                                            <TextBlock x:Name="TxtCartItemsCountCompletar" Text="0" FontWeight="SemiBold" Foreground="#1E3A8A" Margin="4,0,0,0"/>
                                            <TextBlock Text=" · Total:" Foreground="#1E3A8A" Margin="10,0,0,0"/>
                                            <TextBlock x:Name="TxtCartItemsTotalCompletar" Text="$ 0" FontWeight="SemiBold" Foreground="#1E3A8A" Margin="4,0,0,0"/>
                                        </StackPanel>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                    <Button Content="+ Ítem" Style="{StaticResource GhostButton}" Padding="10,4" Margin="0,0,6,0" Click="BtnAddGastoItem_Click" ToolTip="Agrega un ítem al grupo actual"/>
                                                    <Button Content="📄 Nueva factura" Style="{StaticResource GhostButton}" Padding="10,4" Click="BtnAddFacturaGroup_Click" ToolTip="Crear un nuevo grupo de factura"/>
                                                </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="Factura compartida para varios ítems (opcional)" FontWeight="SemiBold" Foreground="#374151"/>
                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="220"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="TxtSharedInvoiceNumberCompletar" Grid.Column="0" Style="{StaticResource ModernTextBoxStyle}" ToolTip="N° factura"/>
                                            <TextBox x:Name="TxtSharedInvoicePathCompletar" Grid.Column="2" Style="{StaticResource ModernTextBoxStyle}" IsReadOnly="True" ToolTip="Ruta factura"/>
                                            <Button Grid.Column="3" Content="Adjuntar" Style="{StaticResource GhostButton}" Margin="8,0,0,0" Padding="10,6" Click="BtnAttachSharedInvoiceCompletar_Click"/>
                                        </Grid>
                                        <Button Content="Aplicar factura compartida a ítems sin factura"
                                                Style="{StaticResource GhostButton}"
                                                Margin="0,8,0,0"
                                                Padding="10,6"
                                                HorizontalAlignment="Left"
                                                Click="BtnApplySharedInvoiceCompletar_Click"/>
                                    </StackPanel>
                                </Border>

                                <ItemsControl x:Name="IcItemsGasto">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <!-- Card de Factura/Grupo -->
                                            <Border BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,12" Background="White">
                                                <StackPanel>
                                                    <!-- Header de Factura -->
                                                    <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="0,0,0,8" Margin="0,0,0,10">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding NumeroFactura, StringFormat='📄 {0}'}" FontWeight="SemiBold" Foreground="#1F2937" FontSize="12"/>
                                                                <TextBlock Text="{Binding ProveedorFactura, StringFormat='Proveedor: {0}'}" Foreground="#6B7280" FontSize="10" Margin="0,2,0,0"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                                                <TextBlock Text="Total: $" Foreground="#374151" FontWeight="SemiBold"/>
                                                                <TextBlock Text="{Binding TotalGrupo, StringFormat='{}{0:N0}'}" Foreground="#1F2937" FontWeight="SemiBold" Margin="4,0,0,0"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>

                                                    <!-- Items del Grupo -->
                                                    <ItemsControl ItemsSource="{Binding Items}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="White" BorderBrush="#F0F0F0" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,0,6">
                                                                    <Grid>
                                                                        <Grid.RowDefinitions>
                                                                            <RowDefinition Height="Auto"/>
                                                                            <RowDefinition Height="Auto"/>
                                                                        </Grid.RowDefinitions>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="130"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="130"/>
                                                                            <ColumnDefinition Width="100"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>

                                                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Tipo de gasto" FontSize="10" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,3"/>
                                                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="Descripción" FontSize="10" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,3"/>
                                                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="Proveedor" FontSize="10" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,3"/>
                                                                        <TextBlock Grid.Row="0" Grid.Column="3" Text="Valor ($)" FontSize="10" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,3"/>

                                                                        <ComboBox Grid.Row="1" Grid.Column="0" Margin="0,0,6,0" Height="28" SelectedValuePath="Tag" SelectedValue="{Binding TipoGasto}">
                                                                            <ComboBoxItem Content="Repuesto" Tag="1"/>
                                                                            <ComboBoxItem Content="Mano de obra" Tag="2"/>
                                                                            <ComboBoxItem Content="Servicio externo" Tag="3"/>
                                                                            <ComboBoxItem Content="Otro" Tag="4"/>
                                                                        </ComboBox>
                                                                        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,0,6,0" Text="{Binding Descripcion}" Style="{StaticResource ModernTextBoxStyle}" Height="28"/>
                                                                        <TextBox Grid.Row="1" Grid.Column="2" Margin="0,0,6,0" Text="{Binding Proveedor}" Style="{StaticResource ModernTextBoxStyle}" Height="28"/>
                                                                        <TextBox Grid.Row="1" Grid.Column="3" Margin="0,0,6,0" Text="{Binding ValorInput}" Style="{StaticResource ModernTextBoxStyle}" Height="28"/>
                                                                        <Button Grid.Row="1" Grid.Column="4" Content="✕" Width="24" Height="24" Click="BtnRemoveGastoItem_Click" Style="{StaticResource GhostButton}" Foreground="#C0392B" ToolTip="Eliminar item"/>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <!-- Datos Factura del Grupo -->
                                                    <Border Background="#FEF3C7" BorderBrush="#FCD34D" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,8,0,0">
                                                        <StackPanel>
                                                            <TextBlock Text="Datos de la factura para este grupo" FontWeight="SemiBold" FontSize="10" Foreground="#92400E"/>
                                                            <Grid Margin="0,6,0,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="150"/>
                                                                    <ColumnDefinition Width="12"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBox Grid.Column="0" Text="{Binding NumeroFactura}" Style="{StaticResource ModernTextBoxStyle}" ToolTip="N° factura" Height="28" Padding="6,4"/>
                                                                <TextBox Grid.Column="2" Text="{Binding RutaFactura}" Style="{StaticResource ModernTextBoxStyle}" IsReadOnly="True" ToolTip="Ruta del archivo" Height="28" Padding="6,4"/>
                                                            </Grid>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="Si agregas ítems, el costo total del correctivo se calculará automáticamente como suma de los valores." FontSize="10" Foreground="#555" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Factura (PDF/imagen)" FontWeight="SemiBold"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtRutaFactura" Grid.Column="0" IsReadOnly="True" Style="{StaticResource InputStyle}" />
                            <Button Grid.Column="1" Content="Adjuntar" Style="{StaticResource GhostButton}" Margin="8,0,0,0" Padding="10,6" Click="BtnAttachFactura_Click" />
                            <Button Grid.Column="2" Content="Ver" Style="{StaticResource GhostButton}" Margin="8,0,0,0" Padding="10,6" Click="BtnOpenFactura_Click" />
                        </Grid>

                        <TextBlock Text="Observaciones (si hay garantía, incluirla aquí)" FontWeight="SemiBold"/>
                        <TextBox x:Name="TxtObservaciones" Style="{StaticResource InputStyle}" MinHeight="120" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />

                        <TextBlock Text="Planes preventivos ejecutados en esta intervención (opcional)" FontWeight="SemiBold"/>
                        <TextBlock Text="Selecciona los planes ya realizados durante este correctivo. Usa 'Editar nota' para configurar costo personalizado y adjuntar la factura por plan cuando aplique."
                                   FontSize="10" Foreground="#555" TextWrapping="Wrap" Margin="0,2,0,8" />
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" MinHeight="140" MaxHeight="220">
                            <ItemsControl x:Name="IcPlanesPreventivos">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" ItemWidth="320" ItemHeight="Auto" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="310" MinHeight="98" Margin="4" Padding="8"
                                                BorderBrush="#D9D9D9" BorderThickness="1" CornerRadius="8">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="White" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Estado}" Value="Vencido">
                                                            <Setter Property="Background" Value="#FFEBEE" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Estado}" Value="Próximo">
                                                            <Setter Property="Background" Value="#FFF8E1" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Estado}" Value="Vigente">
                                                            <Setter Property="Background" Value="#E8F5E9" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="30"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0" VerticalAlignment="Top" Margin="0,2,0,0" IsChecked="{Binding IsSelected}"/>
                                                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                                        <TextBlock Text="{Binding Nombre}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                                        <Border Margin="0,6,0,0" Padding="6,2" CornerRadius="10" HorizontalAlignment="Left">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#E8F5E9" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Estado}" Value="Vencido">
                                                                            <Setter Property="Background" Value="#FFEBEE" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Estado}" Value="Próximo">
                                                                            <Setter Property="Background" Value="#FFF8E1" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Estado}" Value="Vigente">
                                                                            <Setter Property="Background" Value="#E8F5E9" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="{Binding Estado}" FontSize="10" FontWeight="SemiBold" Foreground="#2E7D32"/>
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>
                                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                                            Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <Button Content="📝 Editar nota" Click="BtnEditPlanNote_Click" Padding="10,4"
                                                            Margin="0,0,8,0" Style="{StaticResource ButtonStyle}"
                                                            Background="#EFF6FF" BorderBrush="#BFDBFE" BorderThickness="1" Foreground="#1E3A8A"
                                                            FontSize="10"/>
                                                    <TextBlock Text="Nota guardada" FontSize="10" Foreground="#2E7D32"
                                                               VerticalAlignment="Center" Margin="0,0,8,0"
                                                               Visibility="{Binding HasDetalleOpcional, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                    <TextBlock Text="Costo personalizado" FontSize="10" Foreground="#1E3A8A"
                                                               VerticalAlignment="Center" Margin="0,0,8,0"
                                                               Visibility="{Binding IsCustomCost, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                    <TextBlock Text="Factura adjunta" FontSize="10" Foreground="#2E5E39"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding InvoicePath, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <TextBlock x:Name="TxtError" Foreground="#C0392B" FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Background="#F5F5F5" Padding="12" CornerRadius="0,0,12,12">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancelar" Style="{StaticResource GhostButton}" Margin="0,0,8,0" Click="BtnCancel_Click"/>
                        <Button Content="Completar" Style="{StaticResource PrimaryButtonStyle}" Click="BtnSave_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
