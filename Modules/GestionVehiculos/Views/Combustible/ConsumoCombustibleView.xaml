<UserControl x:Class="GestLog.Modules.GestionVehiculos.Views.Combustible.ConsumoCombustibleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GestLog.Converters">
    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        
        <!-- Estilo para botones redondos con hover elegante -->
        <Style x:Key="RoundIconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#118938" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BorderBg" 
                                Background="{TemplateBinding Background}"
                                CornerRadius="20"
                                Width="40" Height="40"
                                Effect="{TemplateBinding Effect}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BorderBg" Property="Background" Value="#0D8E35" />
                                <Setter TargetName="BorderBg" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#000000" Opacity="0.18" BlurRadius="10" ShadowDepth="2" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BorderBg" Property="Background" Value="#118938" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" Opacity="0.12" BlurRadius="6" ShadowDepth="2" />
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Estilos para DataGrid -->
        <Style TargetType="DataGrid" x:Key="ConsumoCombustibleDataGridStyle">
            <Setter Property="RowHeight" Value="40" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="AlternatingRowBackground" Value="#FAFAFA" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#EFEFEF" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="RowBackground" Value="White" />
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                        <Setter Property="Padding" Value="6,0" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Foreground" Value="#333" />
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="#0B3F19" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="Background" Value="Transparent" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Estilo para TextBlock centrado en columnas -->
        <Style x:Key="CenteredTextBlockStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
        
        <!-- Estilo para headers del DataGrid -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8F9FA" />
            <Setter Property="Foreground" Value="#504F4E" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="BorderBrush" Value="#E5E5E5" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>
        
        <!-- Estilo para botones de acción en DataGrid -->
        <Style x:Key="ActionIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="6" Width="32" Height="32">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F3FFF3" />
                    <Setter Property="BorderBrush" Value="#E6F6E8" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#E8F9E9" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="#FAFAFA" Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Consumo de combustible" FontSize="16" FontWeight="SemiBold" Foreground="#504F4E"/>
                    <TextBlock Text="Registra, consulta y edita las tanqueadas del vehículo actual." FontSize="12" Foreground="#706F6F" Margin="0,4,0,0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Border Background="#F8FAFC" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="8,4" Margin="0,0,8,0">
                            <TextBlock Text="{Binding TotalRegistros, StringFormat=Registros: {0}}" FontSize="12" FontWeight="SemiBold"/>
                        </Border>
                        <Border Background="#F8FAFC" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="8,4" Margin="0,0,8,0">
                            <TextBlock Text="{Binding TotalGalones, StringFormat=Galones: {0:N2}}" FontSize="12" FontWeight="SemiBold"/>
                        </Border>
                        <Border Background="#F8FAFC" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="8,4">
                            <TextBlock Text="{Binding PromedioCostoPorGalon, StringFormat=Costo/Gal: {0:C2}}" FontSize="12" FontWeight="SemiBold"/>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1" Content="⛽" Click="BtnRegistrarTanqueada_Click" Style="{StaticResource RoundIconButtonStyle}" Margin="8,0,0,0" ToolTip="Registrar tanqueada" FontSize="18"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="8" Padding="8">
            <Grid>
                <DataGrid x:Name="DgTanqueadas"
                          ItemsSource="{Binding Registros}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          Style="{StaticResource ConsumoCombustibleDataGridStyle}"
                          CanUserResizeColumns="True"
                          SelectionMode="Single"
                          SelectionUnit="FullRow">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Fecha" Binding="{Binding FechaTanqueada, StringFormat={}{0:dd/MM/yyyy}}" Width="110" ElementStyle="{StaticResource CenteredTextBlockStyle}"/>
                        <DataGridTextColumn Header="KM" Binding="{Binding KMAlMomento, StringFormat={}{0:N0}}" Width="90" ElementStyle="{StaticResource CenteredTextBlockStyle}"/>
                        <DataGridTextColumn Header="Galones" Binding="{Binding Galones, StringFormat={}{0:N2}}" Width="90" ElementStyle="{StaticResource CenteredTextBlockStyle}"/>
                        <DataGridTextColumn Header="Valor" Binding="{Binding ValorTotal, StringFormat={}{0:C2}}" Width="110" ElementStyle="{StaticResource CenteredTextBlockStyle}"/>
                        <DataGridTextColumn Header="Costo/Gal" Binding="{Binding CostoPorGalon, StringFormat={}{0:C2}}" Width="100" ElementStyle="{StaticResource CenteredTextBlockStyle}"/>
                        <DataGridTextColumn Header="Proveedor" Binding="{Binding Proveedor}" Width="*" ElementStyle="{StaticResource CenteredTextBlockStyle}"/>
                        <DataGridTemplateColumn Header="Acciones" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Button Style="{StaticResource ActionIconButtonStyle}" Content="✏️" Click="BtnEditarTanqueada_Click" ToolTip="Editar" Margin="0,0,4,0" />
                                        <Button Style="{StaticResource ActionIconButtonStyle}" Content="🗑️" Click="BtnEliminarTanqueada_Click" ToolTip="Eliminar" Foreground="#C0392B" />
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Text="{Binding ErrorMessage}" Foreground="#C0392B" Margin="8" VerticalAlignment="Bottom"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
