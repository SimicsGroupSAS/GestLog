<UserControl x:Class="GestLog.Modules.GestionVehiculos.Views.Vehicles.VehicleDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:views="clr-namespace:GestLog.Modules.GestionVehiculos.Views.Vehicles"
             xmlns:mantenimientos="clr-namespace:GestLog.Modules.GestionVehiculos.Views.Mantenimientos"
             xmlns:combustible="clr-namespace:GestLog.Modules.GestionVehiculos.Views.Combustible"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d"
             d:DesignWidth="1000" d:DesignHeight="700">
    <UserControl.Resources>
        <!-- Estilos locales para tabs, coherentes con ModalWindowsStandard / EquiposInformaticos -->
        <Style x:Key="DetailTabItemStyle" TargetType="TabItem">
            <Setter Property="TextElement.Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Padding" Value="12,8"/>
            <!-- Forzar HeaderTemplate para evitar TextBlock automático que puede recibir UnsetValue en Foreground -->
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{Binding RelativeSource={RelativeSource AncestorType=TabItem}, Path=(TextElement.Foreground), FallbackValue={StaticResource TextPrimaryBrush}}"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid>
                            <Border x:Name="Bd"
                                    Background="Transparent"
                                    CornerRadius="8,8,0,0"
                                    Padding="8,6"
                                    Margin="0,0,8,0"
                                    BorderBrush="Transparent"
                                    BorderThickness="1">
                                <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource SurfaceBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                <Setter Property="TextElement.Foreground" Value="{StaticResource PrimaryBrush}"/>
                                <Setter Property="Panel.ZIndex" Value="10"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F3F9F3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NestedTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Cabecera de pestañas: sin márgenes laterales -->
                            <Border Grid.Row="0" Margin="0" Background="{StaticResource WhiteBrush}" BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="8,8,0,0" Padding="8,6">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Focusable="False">
                                    <TabPanel IsItemsHost="True" Background="Transparent" />
                                </ScrollViewer>
                            </Border>

                            <!-- Contenido de la pestaña: sin márgenes ni padding adicional -->
                            <Border Grid.Row="1" Background="{StaticResource WhiteBrush}" BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="0,0,8,8" Margin="0" Padding="0">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="8" ShadowDepth="2" RenderingBias="Quality"/>
                                </Border.Effect>
                                <ContentPresenter ContentSource="SelectedContent" Margin="0"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DetailTabItemStyle}"/>
        </Style>

        <Style x:Key="DetailTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Cabecera de pestañas: fondo blanco con borde, esquinas superiores redondeadas -->
                            <!-- Nota: margen superior interno cambiado a 0 para alinear con la imagen (evita suma doble de márgenes) -->
                            <Border Grid.Row="0" Margin="24,0,24,0" Background="{StaticResource WhiteBrush}" BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="8,8,0,0" Padding="8,6">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Focusable="False">
                                    <TabPanel IsItemsHost="True" Background="Transparent" />
                                </ScrollViewer>
                            </Border>

                            <!-- Contenido de la pestaña con borde y fondo más contrastado, conectado a la cabecera -->
                            <Border Grid.Row="1" Background="{StaticResource WhiteBrush}" BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="0,0,8,8" Margin="24,0,24,24" Padding="8">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" Opacity="0.04" BlurRadius="8" ShadowDepth="2" RenderingBias="Quality"/>
                                </Border.Effect>
                                <ContentPresenter ContentSource="SelectedContent" Margin="0"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DetailTabItemStyle}"/>
        </Style>

        <Style x:Key="HeaderActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#118938" />
            <Setter Property="BorderBrush" Value="#118938" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderDangerButtonStyle" TargetType="Button" BasedOn="{StaticResource HeaderActionButtonStyle}">
            <Setter Property="Background" Value="#DC2626" />
            <Setter Property="BorderBrush" Value="#DC2626" />
        </Style>
    </UserControl.Resources>
    <Grid Background="#FAFAFA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>        <!-- Header con título del vehículo (Marca Modelo Año) -->
        <Border Grid.Row="0" Background="#FFF" BorderBrush="#E5E5E5" BorderThickness="0,0,0,1" Padding="20,10" MinHeight="104">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Foto del vehículo -->
                <Border Grid.Column="0"
                        Width="120"
                        VerticalAlignment="Stretch"
                        CornerRadius="10"
                        Background="#F7F7F7"
                        BorderBrush="#E5E5E5"
                        BorderThickness="1"
                        ClipToBounds="True">
                    <Image Stretch="Uniform">
                        <Image.Source>
                            <PriorityBinding>
                                <Binding Path="PhotoPath" />
                                <Binding Path="PhotoThumbPath" />
                            </PriorityBinding>
                        </Image.Source>
                    </Image>
                </Border>

                <!-- Center: Title + subtitle + chips -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock FontSize="24" FontWeight="SemiBold" Foreground="#118938" Text="{Binding VehicleTitle}" />
                    <TextBlock FontSize="13" Foreground="#706F6F" Text="{Binding PlateDisplay}" Margin="0,4,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#FFFFFF" BorderBrush="#EDEDED" BorderThickness="1" CornerRadius="6" Padding="8,4" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="KM: " FontSize="12" Foreground="#706F6F" Margin="0,0,4,0"/>
                                <TextBlock Text="{Binding Mileage, StringFormat={}{0:N0} km}" FontSize="12" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#FFFFFF" BorderBrush="#EDEDED" BorderThickness="1" CornerRadius="6" Padding="8,4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Próx. mant.: " FontSize="12" Foreground="#706F6F" Margin="0,0,4,0"/>
                                <TextBlock Text="{Binding ProximoMantenimientoDisplay}" FontSize="12" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <!-- Right: Actions -->
                <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Border Background="#FFFFFF" BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="8" Padding="8" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="Actualizar KM" FontSize="11" FontWeight="SemiBold" Foreground="#504F4E" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBox Width="110"
                                         Height="34"
                                         Text="{Binding NuevoKilometrajeInput, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="8,4"
                                         FontSize="12"
                                         BorderBrush="#D0D0D0"
                                         BorderThickness="1"
                                         VerticalContentAlignment="Center"
                                         Margin="0,0,8,0"/>
                                <Button Content="🔄"
                                        Command="{Binding ActualizarKilometrajeCommand}"
                                        Style="{StaticResource HeaderActionButtonStyle}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="🔧" Click="BtnQuickMantenimiento_Click" Style="{StaticResource HeaderActionButtonStyle}" Margin="0,0,8,0" ToolTip="Agregar mantenimiento" />
                        <Button Content="⛽" Click="BtnQuickTanqueada_Click" Style="{StaticResource HeaderActionButtonStyle}" Margin="0,0,8,0" ToolTip="Registrar tanqueada" />
                        <Button Content="✏️" Command="{Binding EditarVehiculoCommand}" Style="{StaticResource HeaderActionButtonStyle}" Margin="0,0,8,0" ToolTip="Editar" />
                        <Button Content="🗑️" Command="{Binding EliminarVehiculoCommand}" Style="{StaticResource HeaderDangerButtonStyle}" ToolTip="Eliminar" />
                    </StackPanel>
                </StackPanel>

            </Grid>
        </Border>

        <!-- Contenido principal -->
        <Grid Grid.Row="1">
            <TabControl x:Name="MainTabControl" Margin="0,16,0,0" Style="{StaticResource DetailTabControlStyle}">
                <TabItem Header="General">
                    <ScrollViewer>
                        <StackPanel Margin="16">
                            <TextBlock Text="KPIs operativos" FontSize="16" FontWeight="SemiBold" Foreground="#504F4E" Margin="0,0,0,12" />

                            <UniformGrid Columns="3" Rows="3" Margin="-6,0,0,12">
                                <Border Background="#FFF" BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="8" Padding="12" Margin="6">
                                    <StackPanel>
                                        <TextBlock Text="Tanqueadas" FontSize="12" Foreground="#706F6F" />
                                        <TextBlock Text="{Binding TotalTanqueadas}" FontSize="20" FontWeight="Bold" Foreground="#118938" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#FFF" BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="8" Padding="12" Margin="6">
                                    <StackPanel>
                                        <TextBlock Text="Galones consumidos" FontSize="12" Foreground="#706F6F" />
                                        <TextBlock Text="{Binding TotalGalonesConsumidos, StringFormat='{}{0:N2} gal'}" FontSize="20" FontWeight="Bold" Foreground="#118938" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#FFF" BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="8" Padding="12" Margin="6">
                                    <StackPanel>
                                        <TextBlock Text="Costo combustible" FontSize="12" Foreground="#706F6F" />
                                        <TextBlock Text="{Binding TotalCostoCombustible, StringFormat='{}{0:C0}'}" FontSize="20" FontWeight="Bold" Foreground="#118938" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#FFF" BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="8" Padding="12" Margin="6">
                                    <StackPanel>
                                        <TextBlock Text="Mantenimientos" FontSize="12" Foreground="#706F6F" />
                                        <TextBlock Text="{Binding CantidadMantenimientos}" FontSize="20" FontWeight="Bold" Foreground="#118938" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#FFF" BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="8" Padding="12" Margin="6">
                                    <StackPanel>
                                        <TextBlock Text="Costo mantenimiento" FontSize="12" Foreground="#706F6F" />
                                        <TextBlock Text="{Binding CostoTotalMantenimiento, StringFormat='{}{0:C0}'}" FontSize="20" FontWeight="Bold" Foreground="#118938" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#FFF" BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="8" Padding="12" Margin="6">
                                    <StackPanel>
                                        <TextBlock Text="Costo operación" FontSize="12" Foreground="#706F6F" />
                                        <TextBlock Text="{Binding CostoTotalOperacion, StringFormat='{}{0:C0}'}" FontSize="20" FontWeight="Bold" Foreground="#118938" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#FFF" BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="8" Padding="12" Margin="6">
                                    <StackPanel>
                                        <TextBlock Text="Costo por km" FontSize="12" Foreground="#706F6F" />
                                        <TextBlock Text="{Binding CostoPorKmDisplay}" FontSize="18" FontWeight="Bold" Foreground="#118938" Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#FFF" BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="8" Padding="12" Margin="6">
                                    <StackPanel>
                                        <TextBlock Text="Próximo mantenimiento" FontSize="12" Foreground="#706F6F" />
                                        <TextBlock Text="{Binding ProximoMantenimientoDisplay}" FontSize="14" FontWeight="SemiBold" Foreground="#1D1D1B" Margin="0,8,0,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#FFF" BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="8" Padding="12" Margin="6">
                                    <StackPanel>
                                        <TextBlock Text="Documentos (vigentes / total)" FontSize="12" Foreground="#706F6F" />
                                        <TextBlock FontSize="18" FontWeight="Bold" Foreground="#118938" Margin="0,8,0,0">
                                            <Run Text="{Binding DocumentosVigentes}"/>
                                            <Run Text=" / "/>
                                            <Run Text="{Binding TotalDocumentos}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <TextBlock Text="Gráficos" FontSize="14" FontWeight="SemiBold" Foreground="#504F4E" Margin="0,6,0,8" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Combustible: consumo promedio -->
                                <Border Grid.Row="0" Grid.Column="0" Background="#FFF" BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,10,10">
                                    <StackPanel>
                                        <TextBlock Text="Consumo promedio (km/gal) a través del tiempo" FontSize="13" FontWeight="SemiBold" Foreground="#504F4E" Margin="0,0,0,8" />
                                        <lvc:CartesianChart Height="180"
                                                            Series="{Binding ConsumoPromedioSeries}"
                                                            XAxes="{Binding ChartDateAxes}"
                                                            YAxes="{Binding ChartConsumptionAxes}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Combustible: gasto mensual -->
                                <Border Grid.Row="0" Grid.Column="1" Background="#FFF" BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="Gasto mensual en combustible" FontSize="13" FontWeight="SemiBold" Foreground="#504F4E" Margin="0,0,0,8" />
                                        <lvc:CartesianChart Height="180"
                                                            Series="{Binding CostoMensualSeries}"
                                                            XAxes="{Binding ChartMonthAxes}"
                                                            YAxes="{Binding ChartCurrencyAxes}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Mantenimientos timeline -->
                                <Border Grid.Row="1" Grid.Column="0" Background="#FFF" BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,10,10">
                                    <StackPanel>
                                        <TextBlock Text="Mantenimientos" FontSize="13" FontWeight="SemiBold" Foreground="#504F4E" Margin="0,0,0,8" />
                                        <lvc:CartesianChart Height="180"
                                                            Series="{Binding MantenimientosTimelineSeries}"
                                                            XAxes="{Binding ChartMaintenanceAxes}"
                                                            YAxes="{Binding ChartMaintenanceCountAxes}" />
                                        <ItemsControl ItemsSource="{Binding MantenimientosTitulos}" Margin="0,8,0,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#F8FAFC" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="6" Padding="6,3" Margin="0,0,6,6">
                                                        <TextBlock Text="{Binding}" FontSize="11" Foreground="#4B5563" TextWrapping="Wrap" MaxWidth="220"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- Kilometraje -->
                                <Border Grid.Row="1" Grid.Column="1" Background="#FFF" BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="Kilometraje" FontSize="13" FontWeight="SemiBold" Foreground="#504F4E" Margin="0,0,0,8" />
                                        <lvc:CartesianChart Height="180"
                                                            Series="{Binding KilometrajeSeries}"
                                                            XAxes="{Binding ChartDateAxes}"
                                                            YAxes="{Binding ChartKmAxes}" />
                                    </StackPanel>
                                </Border>

                                <!-- Pie costos totales -->
                                <Border Grid.Row="2" Grid.Column="0" Background="#FFF" BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,10,0">
                                    <StackPanel>
                                        <TextBlock Text="Costos totales" FontSize="13" FontWeight="SemiBold" Foreground="#504F4E" Margin="0,0,0,8" />
                                        <lvc:PieChart Height="180" Series="{Binding DistribucionGastoSeries}" LegendPosition="Bottom" />
                                    </StackPanel>
                                </Border>

                                <!-- Documentos/otro recomendado -->
                                <Border Grid.Row="2" Grid.Column="1" Background="#FFF" BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="8" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="Documentos" FontSize="13" FontWeight="SemiBold" Foreground="#504F4E" Margin="0,0,0,8" />
                                        <lvc:PieChart Height="180" Series="{Binding DocumentosPieSeries}" LegendPosition="Bottom" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <TextBlock Text="Ficha completa del vehículo" FontSize="14" FontWeight="SemiBold" Foreground="#504F4E" Margin="0,8,0,8" />
                            <Border Background="#FFF" BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="8" Padding="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,8">
                                        <TextBlock Text="Placa" FontSize="12" Foreground="#706F6F" />
                                        <TextBlock Text="{Binding Plate}" FontSize="14" FontWeight="SemiBold" Foreground="#1D1D1B" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                                        <TextBlock Text="VIN" FontSize="12" Foreground="#706F6F" />
                                        <TextBlock Text="{Binding Vin}" FontSize="14" FontWeight="SemiBold" Foreground="#1D1D1B" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,8">
                                        <TextBlock Text="Marca / Modelo" FontSize="12" Foreground="#706F6F" />
                                        <TextBlock Text="{Binding BrandModelDisplay}" FontSize="14" FontWeight="SemiBold" Foreground="#1D1D1B" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                                        <TextBlock Text="Versión" FontSize="12" Foreground="#706F6F" />
                                        <TextBlock Text="{Binding VersionDisplay}" FontSize="14" FontWeight="SemiBold" Foreground="#1D1D1B" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,12,8">
                                        <TextBlock Text="Año" FontSize="12" Foreground="#706F6F" />
                                        <TextBlock Text="{Binding Year}" FontSize="14" FontWeight="SemiBold" Foreground="#1D1D1B" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,8">
                                        <TextBlock Text="Color" FontSize="12" Foreground="#706F6F" />
                                        <TextBlock Text="{Binding ColorDisplay}" FontSize="14" FontWeight="SemiBold" Foreground="#1D1D1B" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,12,8">
                                        <TextBlock Text="Tipo" FontSize="12" Foreground="#706F6F" />
                                        <TextBlock Text="{Binding TypeDisplay}" FontSize="14" FontWeight="SemiBold" Foreground="#1D1D1B" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,8">
                                        <TextBlock Text="Estado" FontSize="12" Foreground="#706F6F" />
                                        <TextBlock Text="{Binding StateDisplay}" FontSize="14" FontWeight="SemiBold" Foreground="#1D1D1B" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,12,8">
                                        <TextBlock Text="Combustible" FontSize="12" Foreground="#706F6F" />
                                        <TextBlock Text="{Binding FuelTypeDisplay}" FontSize="14" FontWeight="SemiBold" Foreground="#1D1D1B" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,0,0,8">
                                        <TextBlock Text="Kilometraje" FontSize="12" Foreground="#706F6F" />
                                        <TextBlock Text="{Binding Mileage, StringFormat='{}{0:N0} km'}" FontSize="14" FontWeight="SemiBold" Foreground="#1D1D1B" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="5" Grid.Column="0" Margin="0,0,12,0">
                                        <TextBlock Text="Creado" FontSize="12" Foreground="#706F6F" />
                                        <TextBlock Text="{Binding CreatedAtDisplay}" FontSize="13" Foreground="#1D1D1B" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="5" Grid.Column="1" Margin="0,0,0,0">
                                        <TextBlock Text="Actualizado" FontSize="12" Foreground="#706F6F" />
                                        <TextBlock Text="{Binding UpdatedAtDisplay}" FontSize="13" Foreground="#1D1D1B" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Documentos">
                    <!-- Insertar la vista de documentos como UserControl para mantener separación MVVM -->
                    <!-- El DataContext se asignará desde code-behind en LoadVehicleAsync -->
                    <views:VehicleDocumentsView x:Name="DocumentsView" />
                </TabItem>

                <TabItem Header="Mantenimientos" Padding="0">
                    <TabControl x:Name="MantenimientosTabs" Style="{StaticResource NestedTabControlStyle}">
                        <TabItem Header="Planes" Style="{StaticResource DetailTabItemStyle}">
                            <mantenimientos:PlanesMantenimientoView x:Name="PlanesView" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0" />
                        </TabItem>
                        <TabItem Header="Ejecuciones" Style="{StaticResource DetailTabItemStyle}">
                            <mantenimientos:EjecucionesMantenimientoView x:Name="EjecucionesView" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0" />
                        </TabItem>
                        <TabItem Header="Correctivos" Style="{StaticResource DetailTabItemStyle}">
                            <mantenimientos:CorrectivosMantenimientoView x:Name="CorrectivosView" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="0" />
                        </TabItem>
                    </TabControl>
                </TabItem>

                <TabItem Header="Combustible">
                    <combustible:ConsumoCombustibleView x:Name="CombustibleView" />
                </TabItem>

                <TabItem Header="Historial">
                    <ScrollViewer>
                        <StackPanel Margin="16">
                            <TextBlock Text="Historial Operativo" FontSize="14" FontWeight="SemiBold" Foreground="#504F4E" Margin="0,0,0,12" />
                            <TextBlock Text="Accidentes, infracciones y cambios del vehículo" Foreground="#706F6F" />
                            <!-- Placeholder: implementar lista real más adelante -->
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</UserControl>
